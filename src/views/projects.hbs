<section class="section">
  <div class="section-label">All Projects</div>

  {{#each projects}}
  <a class="project-card" href="{{url}}" target="_blank" rel="noopener">
    <span class="proj-num">{{padStart num}}</span>
    <div>
      <h3>{{title}}</h3>
      <div class="proj-type">{{type}}</div>
      <p>{{description}}</p>
      <div class="tags" style="margin-top:10px;">
        {{#each tags}}<span class="tag">{{this}}</span>{{/each}}
      </div>
      {{#if github}}
      <a class="proj-github" href="{{github}}" target="_blank" rel="noopener" onclick="event.stopPropagation()">
        <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.31 3.435 9.82 8.205 11.405.6.11.82-.26.82-.577v-2.165c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23A11.52 11.52 0 0 1 12 6.844a11.5 11.5 0 0 1 3.01.404c2.29-1.552 3.295-1.23 3.295-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22v3.293c0 .319.21.694.825.576C20.565 22.315 24 17.81 24 12.5 24 5.87 18.63.5 12 .5Z" fill="currentColor"/></svg>
        GitHub
      </a>
      {{/if}}
    </div>
    <span class="proj-arrow" aria-hidden="true">↗</span>
  </a>
  {{/each}}
</section>
