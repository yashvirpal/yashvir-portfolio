<section class="section">
  <div class="section-label">All Projects</div>

  {{#each projects}}
<a class="project-card" href="{{url}}" target="_blank" rel="noopener">
  <span class="proj-num">{{padStart num}}</span>

  <div>
    <h3>{{title}}</h3>
    <div class="proj-type">{{type}}</div>
    <p>{{description}}</p>

    <div class="tags" style="margin-top:10px;">
      {{#each tags}}
        <span class="tag">{{this}}</span>
      {{/each}}
    </div>

    {{#if github}}
    <button
      class="proj-github"
      onclick="event.stopPropagation(); window.open('{{github}}', '_blank')"
    >
      GitHub
    </button>
    {{/if}}
  </div>

  <span class="proj-arrow">↗</span>
</a>
{{/each}}
</section>
