{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "15mb" }
    }
  ],
  "routes": [
    { "src": "/css/(.*)",    "dest": "/public/css/$1"    },
    { "src": "/js/(.*)",     "dest": "/public/js/$1"     },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/(.*)",        "dest": "/api/index.js"     }
  ]
}
